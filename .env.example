PORT=3000
BASE_URL=http://localhost:3000
# Optional: random string for OAuth state HMAC. If unset, derived from LINE+Google secrets.
# OAUTH_STATE_SECRET=
EVENT_ID=MALI_GO_2026
LINE_LOGIN_CHANNEL_ID=YOUR_LINE_LOGIN_CHANNEL_ID
# Must be the secret of THIS LINE Login channel (not Messaging API).
LINE_LOGIN_CHANNEL_SECRET=YOUR_LINE_LOGIN_CHANNEL_SECRET
LINE_OA_ADD_FRIEND_URL=https://line.me/R/ti/p/@YOUR_OA_ID
# Basic ID เช่น @yourid — สำหรับปุ่ม line://ti/p/@... เปิดแอปบนมือถือ
LINE_OA_BASIC_ID=@YOUR_OA_BASIC_ID
# Optional: Channel access token ของ Messaging API (OA เดียวกับ LINE_OA_ADD_FRIEND_URL) — หลังล็อกอิน LINE สำเร็จจะ push ข้อความต้อนรับ + Flex การ์ดทุกครั้ง
# ใช้ชื่อ LINE_MESSAGING_CHANNEL_ACCESS_TOKEN หรือ LINE_CHANNEL_ACCESS_TOKEN อย่างใดอย่างหนึ่ง
# LINE_MESSAGING_CHANNEL_ACCESS_TOKEN=
# LINE_CHANNEL_ACCESS_TOKEN=
# Optional: ข้อความต้อนรับ (บรรทัดใหม่ใช้ \n ใน env)
# LINE_PUSH_WELCOME_TEXT=Welcome...\\n\\nSecond paragraph...
# Optional: รูปใน Flex การ์ด (ถ้าไม่ตั้ง ใช้ CHECKIN_SUCCESS_ARTWORK_URL หรือ /checkin-success-artwork.png)
# LINE_PUSH_CARD_IMAGE_URL=https://example.com/card.png
# Optional: ปุ่ม CLAIM เปิด URL (ถ้าไม่ตั้ง ใช้ LINE_OA_ADD_FRIEND_URL)
# LINE_PUSH_PRIVILEGE_BUTTON_URI=https://liff.line.me/xxxxx
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback
# Local: path to JSON file. Render/cloud: paste full JSON in one line below.
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=C:/path/to/service-account.json
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
GOOGLE_SHEET_ID=1U-f_RH0TySCuIjG0e0dieMbj4gNJuwZbgpxW0sJlWhc
GOOGLE_SHEET_TAB=ชีต1
# Optional: URL รูปบนหน้าสำเร็จหลังล็อกอิน (ถ้าไม่ตั้ง ใช้ไฟล์ public/checkin-success-artwork.png)
# CHECKIN_SUCCESS_ARTWORK_URL=https://example.com/claim-artwork.png
